{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OctoSwitch",
  "version": "0.4.4",
  "identifier": "com.octoswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OctoSwitch",
        "width": 900,
        "height": 556,
        "minWidth": 680,
        "minHeight": 420,
        "backgroundColor": "#070708",
        "backgroundThrottling": "throttle",
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-timer-throttling --disable-renderer-backgrounding --disable-backgrounding-occluded-windows"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
