{
  "octoswitch_base_url": "http://127.0.0.1:8787",
  "namespace": "octoswitch",
  "default_group": "Sonnet",
  "task_routes": {
    "implementation": {
      "group": "Sonnet",
      "delegate_agent_name": "implementation",
      "prompt_template": "按当前确认方案完成实现，并运行相关测试。",
      "enabled": true
    },
    "review": {
      "group": "Opus",
      "delegate_agent_name": "review",
      "prompt_template": "审查当前改动的风险、边界条件和回归影响。",
      "enabled": true
    },
    "search": {
      "group": "Haiku",
      "delegate_agent_name": "search",
      "prompt_template": "搜索相关代码入口并总结影响范围。",
      "enabled": true
    }
  },
  "result_format": [
    "summary",
    "files changed",
    "commands run",
    "test results",
    "unresolved risks"
  ]
}
